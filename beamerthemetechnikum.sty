% Beamer Theme Technikum
% Main theme file for Fachhochschule Technikum Wien
\ProvidesPackage{beamerthemetechnikum}[2025/11/18 Technikum Wien Beamer Theme]

\mode<presentation>

% --- Packages ---

\RequirePackage{tikz}
\RequirePackage{ifthen}                                         % theme option logic
\RequirePackage[european, siunitx]{circuitikz}
\RequirePackage[cache=true]{minted}
\RequirePackage[skip=0.25em, justification=centering]{caption}  % numbered captions

% --- Theme options and utilities ---

\input{utils/options.sty}
\input{utils/commands.sty}
\input{utils/colors.sty}

% --- Package configurations ---

\input{config/tikz.cfg}
\input{config/circuitikz.cfg}
\input{config/minted.cfg}

% --- Theme components ---

\usecolortheme{technikum}
\usefonttheme{technikum}
\useinnertheme{technikum}
\useoutertheme{technikum}

\mode<all>